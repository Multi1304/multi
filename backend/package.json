{
  "name": "camel-farm-backend",
  "version": "1.0.0",
  "description": "Backend for multilogin automation platform — Ultra Deluxe",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:seed": "node setup.js",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/automation.worker.ts",
    "test:single": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run",
    "test": "node scripts/run-vitest-batches.cjs",
    "camel:bootstrap-vpn": "npx ts-node scripts/full-vpn-bootstrap.ts",
    "camel:provision-vps": "npx ts-node scripts/provision-vps.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1011.0",
    "@bull-board/api": "^4.12.2",
    "@bull-board/express": "^4.12.2",
    "@prisma/client": "5.22.0",
    "@types/async-retry": "^1.4.9",
    "@types/rate-limit-redis": "^1.7.4",
    "@types/winston": "^2.4.4",
    "async-retry": "^1.3.3",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.69.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "playwright": "^1.58.2",
    "proxy-chain": "^2.7.1",
    "puppeteer": "^22.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rate-limit-redis": "^4.3.1",
    "requests": "^0.3.0",
    "stripe": "^14.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "dotenv": "^17.3.1",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  }
}
