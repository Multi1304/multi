# ─── Database ──────────────────────────────────────────────────
DATABASE_URL="postgres://postgres:postgres@localhost:5432/multilogin"

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Server ────────────────────────────────────────────────────
PORT=4000

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-string

# ─── Stripe (optional — leave empty to disable billing) ────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_ULTRA=

# ─── Encryption ────────────────────────────────────────────────
ENCRYPTION_KEY=change-this-to-a-32-char-secret!

# ─── Worker ────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
WORKER_ID=worker-1

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Profiles ──────────────────────────────────────────────────
PROFILES_DIR=/app/profiles

# ─── Frontend (for Stripe redirects) ───────────────────────────
FRONTEND_URL=http://localhost:3000
