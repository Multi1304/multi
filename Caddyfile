:80 {
  # Compulsively apply compression for optimized asset loading
  encode gzip zstd

  # Security headers mapping Phase 4.2 specs
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Frame-Options "DENY"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }

  # Route API traffic to the backend Express server
  # Preserving /api prefix for internal backend consistency
  handle /api/* {
    reverse_proxy api:4000 {
      header_up Host {host}
      header_up X-Real-IP {remote}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
    }
  }

  # Route SSE monitor traffic to the backend
  # Ensure it matches the /api/monitor/stream path used by the backend
  handle /api/monitor/stream* {
    reverse_proxy api:4000 {
      header_up Host {host}
      header_up X-Real-IP {remote}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
    }
  }

  # Serve Frontend static application files
  handle {
    root * /srv/frontend
    try_files {path} {path}/ /index.html
    file_server

    # Setup basic cache rules for assets
    @static {
      path *.ico *.css *.js *.gif *.webp *.svg *.png *.jpg *.woff2
    }
    header @static Cache-Control "public, max-age=31536000"
  }
}
